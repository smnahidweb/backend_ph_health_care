model speciality {

id String @id @default(uuid(7))
title String @db.VarChar(100)
description String? @db.VarChar(500)
icon String? @db.VarChar(255)
createAt DateTime @default(now())
updateAt DateTime @default(now())

isDeleted Boolean @default(false)
deleteAt DateTime?
doctors doctorSpeciality[]
@@index([isDeleted],name:"idx_specialty_isDeleted")
@@index([title],name:"idx_specialty_title")
@@map("specialties")

}

model doctorSpeciality {

id String @id @default(uuid(7))
doctorId String
specialityId String

//relations
doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
speciality speciality @relation(fields: [specialityId], references: [id], onDelete: Cascade, onUpdate: Cascade)

@@unique([doctorId, specialityId],name:"unique_doctor_speciality")
@@index([doctorId],name:"idx_doctor_speciality_doctorId")
@@index([specialityId],name:"idx_doctor_speciality_specialityId")

}